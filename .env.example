# Скопируй в .env и заполни.

# Google Sheets
SPREADSHEET_ID=
# Имя листа. Если пусто — берётся первый лист книги.
SHEET_NAME=
# Стартовая колонка диапазона (по умолчанию A).
START_COLUMN=A
# Сколько колонок ожидаем от Gemini. Если 0 — без проверки, диапазон под фактический ответ.
EXPECTED_COLUMNS=5
# Путь к JSON-ключу сервис-аккаунта (внутри контейнера WORKDIR=/config).
SERVICE_ACCOUNT_FILE=service-account.json
# Путь к шаблону промпта.
PROMPT_FILE=prompt.txt

# Gemini
GEMINI_API_KEY=
GEMINI_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite,gemini-2.0-flash
GEMINI_MAX_RETRIES=3

# Хук
# Формат даты для команды `date` в post-commit хуке.
DATE_FORMAT=+%d-%m-%Y
# Имя docker-образа.
REPORT_IMAGE_NAME=report
