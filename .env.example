# Global config for report-helper.
# Copied to ~/.config/report-helper/.env by `report-helper bootstrap`.
# Per-repo overrides go in <repo>/.report-helper/.env (created by `report-helper init`).

# Google Sheets ----------------------------------------------------------------
SPREADSHEET_ID=
# Sheet/tab name. Empty = first sheet of the workbook.
SHEET_NAME=
# Range start column (default A).
START_COLUMN=A
# Expected number of CSV columns from Gemini. 0 = no validation; range adapts.
EXPECTED_COLUMNS=5
# Service account JSON. Default resolves to /config/service-account.json (global).
# To override per-repo: set to /config-repo/service-account.json in the per-repo .env.
SERVICE_ACCOUNT_FILE=service-account.json
# Prompt template path. Same convention as SERVICE_ACCOUNT_FILE.
PROMPT_FILE=prompt.txt

# Gemini -----------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite,gemini-2.0-flash
GEMINI_MAX_RETRIES=3

# CLI / hook -------------------------------------------------------------------
# Date format passed to the shell `date` command (used by post-commit hook).
DATE_FORMAT=+%d-%m-%Y
# Docker image name.
REPORT_IMAGE_NAME=report
# Log file. Default: <parent-repo>/hook.log
# REPORT_LOG_FILE=
